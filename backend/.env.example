# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/k8s_agent
DATABASE_USERNAME=k8s_user
DATABASE_PASSWORD=k8s_password

# JWT Configuration
# JWT_SECRET must be at least 32 characters long for HS256 algorithm
# Use a strong random string without special Base64 characters
# Example: generate with: openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
JWT_SECRET=YourSuperSecretJWTKeyMustBeAtLeast32CharactersLongForHS256
JWT_EXPIRATION=86400000

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Kubernetes Configuration
KUBECONFIG_PATH=/path/to/your/kubeconfig